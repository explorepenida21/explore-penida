# ============================================================
# Explore Penida - Environment Variables Template
# Copy file ini ke .env dan isi dengan nilai yang benar
# JANGAN COMMIT FILE .env ke repository!
# ============================================================

# ============================================================
# Database PostgreSQL
# ============================================================
# Untuk Rumahweb, gunakan PostgreSQL yang tersedia
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/explore_penida"

# ============================================================
# NextAuth Configuration
# ============================================================
# Generate secret baru dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ISI_DENGAN_SECRET_BARU_32_KARAKTER"
NEXTAUTH_URL="https://DOMAIN_ANDA.com"

# ============================================================
# Midtrans Payment Gateway
# ============================================================
# Dapatkan dari: https://dashboard.midtrans.com
# AMANKAN: Server Key adalah secret, JANGAN expose di frontend!

# Mode Production (ubah ke 'true' setelah testing selesai)
MIDTRANS_IS_PRODUCTION="false"

# Server Key - HANYA untuk backend (RAHASIA!)
MIDTRANS_SERVER_KEY="ISI_MIDTRANS_SERVER_KEY_ANDA"

# Client Key - Boleh di-expose ke frontend
MIDTRANS_CLIENT_KEY="ISI_MIDTRANS_CLIENT_KEY_ANDA"

# Webhook URL - Diisi di Midtrans Dashboard
# https://dashboard.midtrans.com/settings/vt_config
MIDTRANS_WEBHOOK_URL="https://DOMAIN_ANDA.com/api/payment/notification"

# ============================================================
# Cloudinary (Image Upload)
# ============================================================
# Dapatkan dari: https://cloudinary.com/console
# AMANKAN: API Secret adalah secret!

# Cloud Name - Boleh di-expose
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="ISI_CLOUD_NAME_ANDA"

# API Key
CLOUDINARY_API_KEY="ISI_API_KEY_ANDA"
NEXT_PUBLIC_CLOUDINARY_API_KEY="ISI_API_KEY_ANDA"

# API Secret - RAHASIA!
CLOUDINARY_API_SECRET="ISI_API_SECRET_ANDA"

# ============================================================
# Fonnte WhatsApp API
# ============================================================
# Dapatkan dari: https://fonnte.com/dashboard
# AMANKAN: Token adalah secret!

FONNTE_TOKEN="ISI_FONNTE_TOKEN_ANDA"

# Nomor WhatsApp Admin (format: 628xxxxxxxxxx)
ADMIN_WA_NUMBER="628xxxxxxxxxx"

# ============================================================
# Email Configuration (SMTP)
# ============================================================
# Opsi 1: Gmail SMTP (dengan App Password)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="email@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"  # App Password, bukan regular password!
EMAIL_FROM="Explore Penida <noreply@domainanda.com>"

# Opsi 2: Resend (Recommended - Free 100 emails/day)
# Daftar di: https://resend.com
# EMAIL_HOST="smtp.resend.com"
# EMAIL_PORT="587"
# EMAIL_SECURE="false"
# EMAIL_USER="resend"
# EMAIL_PASS="re_xxxxx"

# ============================================================
# AI Chat Configuration
# ============================================================
# OpenRouter (Free tier available)
# Daftar di: https://openrouter.ai
OPENROUTER_API_KEY="ISI_OPENROUTER_API_KEY_ANDA"

# ============================================================
# Application URLs
# ============================================================
# URL utama aplikasi (tanpa trailing slash)
NEXT_PUBLIC_APP_URL="https://DOMAIN_ANDA.com"

# ============================================================
# Google Analytics (Optional)
# ============================================================
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
