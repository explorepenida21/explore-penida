{
  "name": "explore-penida",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "prisma generate && next build --no-lint",
    "build:lint": "prisma generate && next build",
    "build:production": "prisma generate && next build",
    "start": "next start",
    "start:production": "NODE_ENV=production node server.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "stop:pm2": "pm2 stop explore-penida",
    "restart:pm2": "pm2 restart explore-penida",
    "logs:pm2": "pm2 logs explore-penida",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:production": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "clean": "rm -rf .next node_modules/.cache",
    "rebuild": "npm run clean && npm install && npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/generative-ai": "^0.24.1",
    "@next/third-parties": "^16.2.9",
    "@prisma/client": "^5.22.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^11.2.10",
    "groq-sdk": "^1.2.1",
    "gsap": "^3.15.0",
    "html2pdf.js": "^0.14.0",
    "midtrans-client": "^1.4.3",
    "next": "14.2.4",
    "next-auth": "^4.24.14",
    "next-intl": "^3.26.5",
    "next-pwa": "^0.0.4",
    "nodemailer": "^7.0.13",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "swiper": "^12.2.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.3",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.4",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
