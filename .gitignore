# ============================================================
# Explore Penida - .gitignore
# ============================================================

# ============================================================
# Dependencies
# ============================================================
node_modules/
.pnp/
.pnp.js
yarn.lock
package-lock.json

# ============================================================
# Environment Variables - KRITIS!
# ============================================================
.env
.env.local
.env.development
.env.production
.env.production.local
.env*.local
*.env
!.env.example

# ============================================================
# Next.js Build Output
# ============================================================
.next/
out/
build/
dist/

# ============================================================
# Debug Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================================
# Local Development
# ============================================================
.vercel
.turbo
.cache/

# ============================================================
# IDE & Editor
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Testing & Coverage
# ============================================================
coverage/
.nyc_output/

# ============================================================
# Prisma
# ============================================================
prisma/migrations/**/migration_lock.toml

# ============================================================
# Misc
# ============================================================
*.pem
*.key
*.crt
*.p12
*.pfx

# Private keys and certificates
*.private.key
*.public.key
*.ssl/

# Local uploads
uploads/
data/

# Backup files
*.bak
*.backup
